#!/bin/bash

# loc - 统计项目代码行数（排除指定目录）
# 用法: ./loc [项目路径] [--exclude=路径]

PROJECT_DIR="${1:-.}"
EXCLUDE_DIR="${2:-backend/src/langflow}"

echo "📊 代码行数统计"
echo "=================="
echo "项目目录: $PROJECT_DIR"
echo "排除目录: $EXCLUDE_DIR"
echo ""

# TypeScript
TS_LINES=$(find "$PROJECT_DIR" -type f \( -name "*.ts" -o -name "*.tsx" \) \
  ! -path "*/$EXCLUDE_DIR/*" \
  ! -path "*/node_modules/*" \
  ! -path "*/.git/*" \
  -exec cat {} + 2>/dev/null | wc -l)

# Python
PY_LINES=$(find "$PROJECT_DIR" -type f -name "*.py" \
  ! -path "*/$EXCLUDE_DIR/*" \
  ! -path "*/__pycache__/*" \
  ! -path "*/.git/*" \
  -exec cat {} + 2>/dev/null | wc -l)

TOTAL=$((TS_LINES + PY_LINES))

echo "TypeScript: $TS_LINES 行"
echo "Python:     $PY_LINES 行"
echo "------------------"
echo "总计:       $TOTAL 行"
