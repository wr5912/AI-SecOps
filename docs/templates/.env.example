# AI-SecOps 开发环境变量模板
# 复制为 .env 文件并填入实际值

# ============================================
# 1. 基础服务配置
# ============================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://secops:secops_dev_password@localhost:5432/ai_secops

# Redis
REDIS_URL=redis://localhost:6379/0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/secops_neo4j_password

# ============================================
# 2. LLM 配置 (选择其中一种)
# ============================================

# OpenAI
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-api-key-here
LLM_MODEL_NAME=gpt-4o

# 或 Azure OpenAI
# LLM_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# 或本地模型 (vLLM/Ollama)
# LLM_PROVIDER=vllm
# VLLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct

# ============================================
# 3. 安全与认证
# ============================================

SECRET_KEY=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# 4. 日志与监控
# ============================================

LOG_LEVEL=INFO
ENABLE_LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=ls-your-key

# ============================================
# 5. 外部集成 (可选)
# ============================================

# 微步API (威胁情报)
# THREATBOOK_API_KEY=your-threatbook-key

# VirusTotal
# VT_API_KEY=your-vt-key